{
  "info": {
    "name": "SQL-RAG Agent",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000"
    }
  ],
  "item": [
    {
      "name": "1. Health Check",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/health",
        "description": "Verify the server is running."
      }
    },
    {
      "name": "2. Ingest Schema (use .env DB_URI)",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/ingest",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{}"
        },
        "description": "Extracts schema from the DB_URI set in .env and builds the vector index. Send an empty body to use the default DB_URI."
      }
    },
    {
      "name": "3. Ingest Schema (custom DB URI)",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/ingest",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"db_uri\": \"sqlite:///data/local.db\"\n}"
        },
        "description": "Override the DB URI at ingest time — useful for pointing at a different database without changing .env."
      }
    },
    {
      "name": "4. View Ingested Schema",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/schema",
        "description": "Returns all schema chunks currently loaded. Useful to verify ingestion worked before querying."
      }
    },
    {
      "name": "5. Natural Language Query",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/query",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"question\": \"List all users and their country codes\"\n}"
        },
        "description": "Converts a natural language question to SQL, executes it, and returns the result. Will self-correct up to 3 times on error. Response includes a chat_id for conversation tracking."
      }
    },
    {
      "name": "5a. Resume Chat by ID",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/query?chat_id=984b553e-da34-4ad5-b9b5-773b4a062d87",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"question\": \"Show me something related to the previous query\"\n}"
        },
        "description": "Continue a previous conversation by passing the chat_id as a query parameter. Replace the chat_id with an actual one from a previous response."
      }
    },
    {
      "name": "6. Query — Aggregation",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/query",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"question\": \"Show total travel emissions per user\"\n}"
        }
      }
    },
    {
      "name": "7. Query — Join",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/query",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"question\": \"List users with their household names and latest monthly total CO2e\"\n}"
        }
      }
    },
    {
      "name": "8. View Chat History — List All",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/history",
        "description": "Returns metadata for all active chat sessions, including chat_id, creation time, and message counts."
      }
    },
    {
      "name": "9. View Chat History — Specific Chat",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/history/984b553e-da34-4ad5-b9b5-773b4a062d87",
        "description": "Returns the full conversation history for a specific chat_id (first query + last 4 queries + last 4 responses). Replace the chat_id in the URL with an actual one from a previous query response or /history endpoint."
      }
    }
  ]
}